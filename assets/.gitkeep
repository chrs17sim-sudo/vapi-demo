<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vapi Demo (Avatar)</title>
    <link rel="icon" href="data:," />

    <style>
      body { font-family: system-ui, Arial; padding: 24px; max-width: 920px; margin: 0 auto; }
      label { display: block; margin-top: 12px; font-weight: 600; }
      input { width: 100%; padding: 10px; margin-top: 6px; font-size: 14px; }
      button { padding: 10px 14px; margin-top: 14px; margin-right: 10px; }
      #status { margin-top: 14px; padding: 10px; background: #f6f8fa; border-radius: 8px; white-space: pre-wrap; }
      #debug { margin-top: 14px; padding: 10px; background: #0b1020; color: #d6e1ff; border-radius: 8px; white-space: pre-wrap;
               font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; }
      small { display: block; margin-top: 6px; color: #555; }

      .topRow { display: grid; grid-template-columns: 180px 1fr; gap: 18px; align-items: start; }
      .avatarCard { background: #fff; border: 1px solid #e6e6e6; border-radius: 14px; padding: 14px; }
      .avatarName { font-weight: 700; margin-top: 10px; }
      .avatarState { color: #555; font-size: 13px; margin-top: 2px; }

      /* Avatar image + expression ring */
      .avatarWrap {
        width: 140px; height: 140px; border-radius: 50%;
        margin: 0 auto;
        position: relative;
        overflow: hidden;
        background: #eee;
        box-shadow: 0 10px 20px rgba(0,0,0,.08);
      }
      .avatarWrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transform: scale(1.02);
        transition: transform .2s ease, filter .2s ease;
      }
      .ring {
        position: absolute; inset: 0;
        border-radius: 50%;
        box-shadow: 0 0 0 0 rgba(0,0,0,0);
        pointer-events: none;
      }

      /* States */
      body.state-idle .avatarWrap img { filter: none; }
      body.state-listening .ring { animation: pulseBlue 1.2s infinite; }
      body.state-speaking .ring { animation: pulseGreen .9s infinite; }
      body.state-speaking .avatarWrap img { transform: scale(1.05); }
      body.state-error .avatarWrap img { filter: grayscale(1) contrast(1.05); }

      @keyframes pulseGreen {
        0% { box-shadow: 0 0 0 0 rgba(76, 175, 80, .45); }
        100% { box-shadow: 0 0 0 18px rgba(76, 175, 80, 0); }
      }
      @keyframes pulseBlue {
        0% { box-shadow: 0 0 0 0 rgba(33, 150, 243, .45); }
        100% { box-shadow: 0 0 0 18px rgba(33, 150, 243, 0); }
      }
    </style>
  </head>

  <body class="state-idle">
    <h1>Vapi Demo</h1>

    <div class="topRow">
      <div class="avatarCard">
        <div class="avatarWrap">
          <!-- Put your local image here -->
          <img
            src="assets/avatar.jpg"
            alt="Assistant avatar"
            onerror="this.style.display='none'; this.parentElement.style.background='#ffd9d9';"
          />
          <div class="ring"></div>
        </div>
        <div class="avatarName">Assistant</div>
        <div class="avatarState" id="avatarState">Idle</div>
        <small>If the avatar is red, the image path is wrong or the file is missing.</small>
      </div>

      <div>
        <label for="publicKey">Vapi Public Key</label>
        <input id="publicKey" placeholder="Paste Vapi PUBLIC key here" autocomplete="off" />

        <label for="assistantId">Assistant ID</label>
        <input id="assistantId" value="20d6b459-5199-4bbd-b1df-9a8cf169aa99" autocomplete="off" />

        <div>
          <button id="startBtn">Start Call</button>
          <button id="stopBtn" disabled>Stop Call</button>
        </div>

        <div id="status">Status: loading SDK…</div>
        <div id="debug">Debug log:</div>
      </div>
    </div>

    <script type="module">
      const statusEl = document.getElementById("status");
      const debugEl = document.getElementById("debug");
      const startBtn = document.getElementById("startBtn");
      const stopBtn = document.getElementById("stopBtn");
      const publicKeyEl = document.getElementById("publicKey");
      const assistantIdEl = document.getElementById("assistantId");
      const avatarStateEl = document.getElementById("avatarState");

      function log(msg, obj) {
        console.log(msg, obj || "");
        debugEl.textContent += `\n${msg}${obj ? " " + JSON.stringify(obj, null, 2) : ""}`;
      }
      function setStatus(text) { statusEl.textContent = `Status: ${text}`; }

      function setAvatar(state, label) {
        document.body.classList.remove("state-idle","state-listening","state-speaking","state-error");
        document.body.classList.add(`state-${state}`);
        avatarStateEl.textContent = label || state;
      }

      let vapi = null;
      let inCall = false;

      function setButtons() {
        startBtn.disabled = inCall;
        stopBtn.disabled = !inCall;
      }

      const PINNED = "2.4.0";

      setStatus(`importing @vapi-ai/web@${PINNED}…`);
      let Vapi;
      try {
        const mod = await import(`https://esm.sh/@vapi-ai/web@${PINNED}`);
        Vapi = mod.default;
        setStatus(`SDK loaded (@vapi-ai/web@${PINNED})`);
        setAvatar("idle", "Ready");
      } catch (e) {
        setStatus("SDK import failed (see debug log)");
        log("Import failed", { message: e?.message, stack: e?.stack });
        setAvatar("error", "SDK load failed");
        throw e;
      }

      startBtn.addEventListener("click", async () => {
        const publicKey = publicKeyEl.value.trim();
        const assistantId = assistantIdEl.value.trim();
        if (!publicKey) return setStatus("missing public key");
        if (!assistantId) return setStatus("missing assistant id");

        try {
          if (!vapi) {
            vapi = new Vapi(publicKey);

            vapi.on("call-start", () => {
              inCall = true;
              setButtons();
              setStatus("in call");
              setAvatar("listening", "In call (listening)");
            });

            vapi.on("call-end", () => {
              inCall = false;
              setButtons();
              setStatus("ended");
              setAvatar("idle", "Ended");
            });

            vapi.on("speech-start", () => setAvatar("speaking", "Speaking"));
            vapi.on("speech-end", () => setAvatar("listening", "Listening"));

            vapi.on("error", (e) => {
              log("Vapi error", e);
              setStatus(`error: ${e?.error?.message || e?.message || "see debug log"}`);
              setAvatar("error", "Error");
            });
          }

          setStatus("starting… (allow microphone)");
          setAvatar("listening", "Requesting mic…");
          await vapi.start(assistantId);
        } catch (e) {
          log("Start failed", { message: e?.message, stack: e?.stack });
          setStatus("failed to start (see debug log)");
          setAvatar("error", "Start failed");
        }
      });

      stopBtn.addEventListener("click", async () => {
        try {
          if (!vapi) return;
          setStatus("stopping…");
          setAvatar("idle", "Stopping…");
          await vapi.stop();
        } catch (e) {
          log("Stop failed", { message: e?.message, stack: e?.stack });
          setStatus("failed to stop (see debug log)");
          setAvatar("error", "Stop failed");
        }
      });

      setButtons();
    </script>
  </body>
</html>
